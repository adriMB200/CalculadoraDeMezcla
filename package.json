{
  "type": "module",
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "@netlify/functions": "^5.1.2",
    "@netlify/neon": "^0.1.2",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.1",
    "electron-store": "^11.0.2",
    "jsonwebtoken": "^9.0.3",
    "node-fetch": "^3.3.2",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0"
  },
  "name": "enduronalon-app",
  "version": "1.0.0",
  "description": "Develop by adriMB200",
  "author": "adriMB200",
  "main": "main.cjs",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.enduronalon.app",
    "productName": "Enduronalon",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist",
      "!node_modules/.cache"
    ],
    "win": {
      "target": "nsis",
      "icon": "imagen/img.jpg"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  }
}